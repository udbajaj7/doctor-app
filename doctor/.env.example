# Build-time configuration for the INCUE Doctor Flutter app.
#
# Flutter does not read this file at runtime. These values are passed to the
# build/run commands via --dart-define (see README). This file documents the
# supported variables and their expected shape. Do NOT put real secrets here.

# Base URL of the INCUE backend API. Must end with a trailing slash.
# Example:
#   flutter run --dart-define=API_BASE_URL=https://api.example.com/
API_BASE_URL=https://your-backend-host.example.com/
